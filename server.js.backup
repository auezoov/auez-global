// Test route to check database data
app.get('/api/test', (req, res) => {
  db.all("SELECT * FROM shift_history LIMIT 5", (err, rows) => {
    if (err) {
      return res.status(500).json({ error: err.message })
    }
    res.json({ data: rows })
  })
})

// Add session record (when PC session starts/ends)
app.post('/api/sessions', authenticateToken, (req, res) => {
  const { pcId, action, revenue } = req.body

  if (action === 'end' && revenue) {
    // Update today's shift income
    db.get(
      "SELECT id FROM shift_history WHERE DATE(shift_start) = DATE('now') ORDER BY created_at DESC LIMIT 1",
      (err, shift) => {
        if (err) {
          return res.status(500).json({ error: 'Database error' })
        }

        if (shift) {
          db.run(
            "UPDATE shift_history SET total_income = total_income + ? WHERE id = ?",
            [revenue, shift.id]
          )
        }
      }
    )
  }

  res.json({ success: true })
})

// Start server
app.listen(PORT, () => {
  console.log(`AUEZ Server running on port ${PORT}`)
  console.log(`Database: ./auez.db`)
  console.log(`API available at: http://localhost:${PORT}/api`)
})
